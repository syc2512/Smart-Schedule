# ============================================================
#  云端大模型 API 配置模板
#  用法：复制本文件为 .env，并填入真实值。.env 请勿提交到仓库。
#  Copy this file to .env and fill in real values. Do NOT commit .env.
# ============================================================

# 必填：API 密钥（从云厂商控制台获取，例如硅基流动 / OpenAI / Groq）
LLM_API_KEY=your-api-key-here

# 可选：API 基址（OpenAI 兼容接口）。默认硅基流动国内可用。
# LLM_BASE_URL=https://api.siliconflow.cn/v1

# 可选：模型名称
# LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# 可选：单次请求超时（秒）
# LLM_TIMEOUT=30

# 可选：设为 true 可跳过真实 API（返回 Mock 数据，用于链路验证）
# LLM_MOCK=false
