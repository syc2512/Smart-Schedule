# ============================================================
# 智能课程表 Pro — 环境变量配置示例
# ============================================================
# 使用方法：
#   1. 复制本文件为 .env （同一目录）
#   2. 修改下面的值为你自己的配置
#   3. 重启 app.py，环境变量会自动加载
#
# 注意：.env 文件包含敏感信息，请勿提交到版本控制系统（建议加入 .gitignore）
# ============================================================

# ---- 大模型配置 (原有) ----
# API Key，从 SiliconFlow / OpenRouter / Groq 等免费 OpenAI 兼容服务获取
LLM_API_KEY=
# API 地址（默认硅基流动）
LLM_BASE_URL=https://api.siliconflow.cn/v1
# 模型名
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
# 请求超时（秒）
LLM_TIMEOUT=30
# Mock 模式（不调用真实 API，用于链路测试）
LLM_MOCK=false


# ---- 用户配置管理系统 ----

# 主密钥：用于加密 API_KEY 与签名 Session
# 生产环境必须设置！建议 32+ 字符随机字符串，可用以下命令生成：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# 警告：更换密钥后，已加密的 API_KEY 将无法解密（需用户重新填写）
TIMETABLE_SECRET_KEY=please-change-me-to-a-32-char-random-string

# Cookie 安全：生产环境（HTTPS）设为 true
TIMETABLE_COOKIE_SECURE=false

# ---- MySQL 数据库连接 ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=timetable_pro
DB_CHARSET=utf8mb4
DB_POOL_SIZE=8
DB_CONNECT_TIMEOUT=10
DB_CONN_MAX_AGE=3600
