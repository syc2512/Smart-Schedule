{
  "_comment": "统一日志系统配置。环境变量 LOG_LEVEL/LOG_DIR/LOG_CONSOLE/LOG_FILE/APP_ENV 优先级最高。",
  "_env_doc": "APP_ENV=dev|test|prod 决定环境预设；LOG_LEVEL=DEBUG|INFO|WARN|ERROR 覆盖级别；LOG_DIR 指定日志目录。",

  "format": "%(asctime)s | %(levelname)-7s | %(name)-16s | [%(request_id)s] | %(message)s",

  "_global_doc": "以下为全局默认值，dev/test/prod 段会覆盖对应字段。",
  "console_enabled": true,
  "console_color": true,
  "file_enabled": true,
  "file_rolling": "time",
  "file_when": "midnight",
  "file_interval": 1,
  "file_backup_count": 30,
  "file_max_bytes": "10MB",
  "error_file_enabled": true,
  "gzip_old_logs": true,

  "dev": {
    "_comment": "开发环境：DEBUG 级别，彩色控制台，文件保留 7 天",
    "level": "DEBUG",
    "console_enabled": true,
    "console_color": true,
    "file_enabled": true,
    "file_backup_count": 7,
    "error_file_enabled": false
  },

  "test": {
    "_comment": "测试环境：INFO 级别，文件保留 14 天",
    "level": "INFO",
    "console_enabled": true,
    "console_color": true,
    "file_enabled": true,
    "file_backup_count": 14,
    "error_file_enabled": true
  },

  "prod": {
    "_comment": "生产环境：INFO 级别，关闭彩色（便于采集），文件保留 30 天，ERROR 单独文件",
    "level": "INFO",
    "console_enabled": true,
    "console_color": false,
    "file_enabled": true,
    "file_backup_count": 30,
    "error_file_enabled": true,
    "gzip_old_logs": true
  }
}
