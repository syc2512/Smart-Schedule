# ============================================================
# 智能课程表 Pro — 环境变量配置示例
# ============================================================
# 使用方法：
#   1. 复制本文件为 .env （同一目录）
#   2. 修改下面的值为你自己的配置
#   3. 重启 app.py，环境变量会自动加载
#
# 注意：.env 文件包含敏感信息，请勿提交到版本控制系统（建议加入 .gitignore）
# ============================================================



# ---- AI 空闲规划（后端代理式；Key 仅存服务端，绝不出现在前端/响应中）----
# AI 服务商 Base URL（OpenAI 兼容接口，可替换为 DeepSeek / 通义 / 本地网关 等）
TIMETABLE_AI_BASE_URL=https://api.openai.com/v1
# AI API Key（仅服务端使用；留空则 /api/ai/plan 自动降级为本地规则版）
TIMETABLE_AI_API_KEY=
# 请求超时（秒；免费模型偶发冷启动可达 10~20s，建议 ≥60 以免误判超时）
TIMETABLE_AI_TIMEOUT=60
# 限流：每秒最多请求数（模块级令牌桶，单进程内生效）
TIMETABLE_AI_RATE_LIMIT=1
# 默认模型
TIMETABLE_AI_MODEL=gpt-4o-mini
# 允许的前端跨域来源（逗号分隔；同源由 app.py 直接服务）
TIMETABLE_CORS_ORIGIN=http://localhost:8000

# ---- 日志系统 ----
# 环境：dev=DEBUG+彩色+7天 / test=INFO+14天 / prod=INFO+无色+30天+ERROR单独文件
APP_ENV=dev
# 覆盖日志级别（DEBUG/INFO/WARN/ERROR）
LOG_LEVEL=
# 日志目录（默认 项目根/logs）
LOG_DIR=
# 是否启用控制台 / 文件输出
LOG_CONSOLE=true
LOG_FILE=true
