# ============================================================
# 智能课程表 Pro — 环境变量配置示例
# ============================================================
# 使用方法：
#   1. 复制本文件为 .env （同一目录）
#   2. 修改下面的值为你自己的配置
#   3. 重启 app.py，环境变量会自动加载
#
# 注意：.env 文件包含敏感信息，请勿提交到版本控制系统（建议加入 .gitignore）
# ============================================================



# ---- 用户配置管理系统 ----

# 主密钥：用于加密 API_KEY 与签名 Session
# 生产环境必须设置！建议 32+ 字符随机字符串，可用以下命令生成：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# 警告：更换密钥后，已加密的 API_KEY 将无法解密（需用户重新填写）
TIMETABLE_SECRET_KEY=please-change-me-to-a-32-char-random-string

# Cookie 安全：生产环境（HTTPS）设为 true
TIMETABLE_COOKIE_SECURE=false

# ---- MySQL 数据库连接 ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=timetable_pro
DB_CHARSET=utf8mb4
DB_POOL_SIZE=8
DB_CONNECT_TIMEOUT=10
DB_CONN_MAX_AGE=3600


# ---- 日志系统 ----
# 环境：dev=DEBUG+彩色+7天 / test=INFO+14天 / prod=INFO+无色+30天+ERROR单独文件
APP_ENV=dev
# 覆盖日志级别（DEBUG/INFO/WARN/ERROR）
LOG_LEVEL=
# 日志目录（默认 项目根/logs）
LOG_DIR=
# 是否启用控制台 / 文件输出
LOG_CONSOLE=true
LOG_FILE=true
